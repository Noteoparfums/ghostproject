{
  "name": "ghostwriter-os",
  "version": "0.1.0",
  "private": true,
  "description": "Ghostwriter OS — production-grade AI SaaS platform (monorepo)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "shared",
    "server",
    "scripts",
    "client"
  ],
  "scripts": {
    "migrate": "npm run -w scripts migrate",
    "migrate:status": "npm run -w scripts migrate:status",
    "seed": "npm run -w scripts seed",
    "db:reset": "npm run -w scripts db:reset",
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "typecheck": "tsc -b shared server scripts --pretty",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vitest": "^2.1.3"
  },
  "dependencies": {
    "mysql2": "^3.11.3",
    "zod": "^3.23.8"
  }
}

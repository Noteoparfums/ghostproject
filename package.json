{
  "name": "ghostwriter-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "shared",
    "scripts"
  ],
  "scripts": {
    "typecheck": "tsc -b tsconfig.base.json shared/tsconfig.json scripts/tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:status": "tsx scripts/migrate-status.ts",
    "seed": "tsx scripts/seed.ts",
    "db:reset": "tsx scripts/db-reset.ts",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run migrate -- --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "mysql2": "^3.11.5",
    "zod": "^3.24.1"
  }
}

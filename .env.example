# Database
DATABASE_URL=mysql://root:root@127.0.0.1:3306/ghostwriter_dev

# Port & Node Environment
PORT=4001
NODE_ENV=development

# App config
APP_URL=http://localhost:5173
APP_VERSION=0.1.0

# Security (min 32 chars)
JWT_SECRET=some-very-long-secret-key-at-least-32-chars-long

# AI Provider Configuration
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=

# Billing (Stripe / Mock)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MOCK_WEBHOOK_SECRET=dev-webhook-secret

# Mailing
SMTP_URL=

# Observability & Ops
MAINTENANCE_MODE=false
LOG_LEVEL=info
ALERT_WEBHOOK_URL=
SENTRY_DSN=
